# Keyline Studio environment — copy to .env and adjust. All values shown are
# safe development defaults; never commit real secrets.

# --- photogrammetry provider -------------------------------------------------
PHOTOGRAMMETRY_PROVIDER=nodeodm
NODEODM_URL=http://nodeodm:3000
NODEODM_TOKEN=
NODEODM_TIMEOUT_SECONDS=60
PHOTOGRAMMETRY_POLL_SECONDS=10

# --- ODM processing defaults ---------------------------------------------------
ODM_ORTHOPHOTO_RESOLUTION_CM=5
ODM_DEM_RESOLUTION_CM=10
ODM_MAX_PARALLEL_UPLOADS=4
ODM_SPLIT_IMAGE_COUNT=0
ODM_SPLIT_OVERLAP_METERS=150

# --- durable jobs ---------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
# How terrain-analysis runs execute:
#   auto   (default) prefer the RQ worker, fall back to a supervised
#          in-process run when Redis is unreachable (dev convenience)
#   rq     queue only — starting an analysis 503s when Redis is down
#          (recommended in production so a queue outage is visible)
#   inline always in-process (single-machine dev without Redis)
ANALYSIS_EXECUTION=auto
# A 'running' run whose heartbeat is older than this is swept to a
# retryable failed/WORKER_LOST state (startup + on read):
ANALYSIS_WORKER_LOST_SECONDS=300
# A stage reporting no progress for this long is marked STAGE_STALLED:
ANALYSIS_STAGE_TIMEOUT_SECONDS=600

# --- auth & tenancy ---------------------------------------------------------------
# disabled (default): single-tenant, no tokens — local/self-hosted use only.
# token: every /api request needs "Authorization: Bearer <token>"; bootstrap
# users/orgs via POST /api/admin/users (guarded by ADMIN_TOKEN below).
AUTH_MODE=disabled
# Per-actor throttle on analyze/reanalyze/retry (enforced in token mode;
# set explicitly to enable in disabled mode):
#ANALYSIS_RATE_LIMIT_PER_MINUTE=10

# --- object storage --------------------------------------------------------------
# STORAGE_BACKEND=local stores under backend/data/uploads (dev/tests only).
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://minio:9000
# Endpoint embedded in presigned URLs for the *browser* (docker-internal
# hostnames are not reachable from it):
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=keyline-uploads
S3_ACCESS_KEY_ID=keyline
S3_SECRET_ACCESS_KEY=keyline-dev-secret
S3_SECURE=false
S3_PRESIGN_EXPIRY_SECONDS=3600

# MinIO dev credentials (compose only)
MINIO_ROOT_USER=keyline
MINIO_ROOT_PASSWORD=keyline-dev-secret

# --- upload limits ----------------------------------------------------------------
DRONE_MIN_IMAGES=20
DRONE_MAX_IMAGES=500
DRONE_MAX_FILE_BYTES=62914560          # 60 MB per photo
DRONE_MAX_TOTAL_BYTES=21474836480      # 20 GB per survey
DRONE_ALLOWED_EXTENSIONS=.jpg,.jpeg
DRONE_UPLOAD_CONCURRENCY=4

# --- terrain ------------------------------------------------------------------------
# A drone DTM covering at least this AOI fraction is analyzed alone
# (no Copernicus fetch/fusion):
DRONE_ONLY_MIN_AOI_COVERAGE=0.98

# --- existing backend settings ---------------------------------------------------------
# KEYLINE_DATA=backend/data
# KEYLINE_DB=backend/data/keyline.sqlite
# KEYLINE_HYDRO_ENGINE=            # whitebox | pysheds (auto by default)
AWS_NO_SIGN_REQUEST=YES

# --- self-healing tunnel (see README "Free-tier hosted topology") ----------------
# Random shared secret guarding POST /api/admin/provider-url; the same value
# goes in the tunnel machine's ~/.config/keyline/tunnel.env.
ADMIN_TOKEN=

# --- managed DTM library ---------------------------------------------------------
# Container path for the shared DTM library (compose binds ./data -> /data).
DTM_STORAGE_DIR=/data/dtm
# Roots a "custom server filepath" may live under (the data dir and the DTM
# library itself are always allowed implicitly).
DTM_ALLOWED_EXTERNAL_ROOTS=/data,/app/data
# Per-file upload limit for browser DTM uploads.
DTM_MAX_UPLOAD_MB=1024
